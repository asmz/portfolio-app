{
  "expo": {
    "name": "portfolio-app",
    "slug": "portfolio-app",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "beer.asmz.portfolio",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.jpg"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "baseUrl": "/portfolio-app"
    }
  }
}
